@startuml PenguinDiner

class Personaje
class Cliente{
    - EstadoAnimoCliente estadoAnimo
    - EstatusCliente estatusCliente
    - Pedido pedido[]
    - Propina propina
}
class Pareja
class Mesera
{
    + Platillo : LlevarPedido(cliente)
    + Platillo : TomarOrden(cliente, platillo)
}

Cliente --|> Personaje
Mesera --|> Personaje
Pareja --|> Cliente

class EstadoAnimoCliente
class EstatusCliente

Cliente "1" *-- "1" EstadoAnimoCliente
Cliente "1" *-- "1" EstatusCliente

class Restaurante{
    - Reloj reloj
    - Tele tele
    - Mostrador mostrador
    - CajaRegistradora caja
    - Letrero letrero
    - Alfombra alfombra
    - Basura basura
}
class Reloj
class Mesa {
    -Silla sillas[2]
    -Cliente clientes[2]
}
class Tele
class Patin 
{
    + Patinar(patin)
}
class Silla
class Mostrador
{
    + Platillo : Entregar(Pedido)
}
class Basura
{
    - Perdida perdida
    + Perdida: Tirar(Platillo)
}
class Letrero
class Fila
class Alfombra
{
    Fila : Esperar(cantClientes, ordenLlegada)
}
class CajaRegistradora
{
    - Ahorro ahorro
    - MetaVentaDiaria metaDiaria
    - VentaDiaria ventaDiaria
    - TotalVendido total
}

Restaurante "1" *-- "1" Reloj
Restaurante "1" *-- "5" Mesa
Restaurante "1" *-- "0,1" Tele
Restaurante "1" *-- "1" Mostrador
Restaurante "1" *-- "1" CajaRegistradora
Restaurante "1" *-- "0,1" Letrero
Restaurante "1" *-- "1" Alfombra
Restaurante "1" *-- "1" Basura
Mesa "1" *-- "2" Silla
Alfombra "1" *-- "1" Fila

Mesera "1" o-- "1" Patin
Cliente "1" o-- "0,1" Mesa
Cliente "1,2" o-- "0,1" Alfombra
Mesera "1" o-- "1" Mostrador
Mesera "1" o-- "1" Basura

class Pedido {
    - Platillo platillos[2]
    + Platillo : Ordenar(pedido)
}
class Platillo
class Pescado
class Camaron
class Nieve
class MalteadaFresa
class Sopa

Cliente "1" *-- "1" Pedido
Mesera "1" o-- "0..*" Pedido
Pedido "1" *-- "1,2" Platillo

Pescado --|> Platillo
Camaron --|> Platillo
Nieve --|> Platillo
MalteadaFresa --|> Platillo
Sopa --|> Platillo

class Ahorro
class Propina
{
    + VentaDiaria : DejarPropina (estadoAnimo)
}
class MetaVentaDiaria
class VentaDiaria
class Perdida
class TotalVendido

CajaRegistradora "1" *-- "1" Ahorro
CajaRegistradora "1" *-- "1" MetaVentaDiaria
CajaRegistradora "1" *-- "1" VentaDiaria
CajaRegistradora "1" o-- "1" Propina
CajaRegistradora "1" *-- "1" TotalVendido

Cliente "1" o-- "1" Propina
Basura "1" *-- "0..*" Perdida

